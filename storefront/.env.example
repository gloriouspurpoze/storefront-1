# =============================================================================
# Profixer Storefront — environment template
# Copy to `.env.local` and fill in your local backend URL.
# =============================================================================

# Backend API (no trailing slash). Matches admin .env REACT_APP_API_URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8005/api

# Host suffixes the storefront serves as platform subdomains.
NEXT_PUBLIC_STOREFRONT_HOST_SUFFIXES=profixer.app,profixer.localhost,localhost

# Optional: Vercel Edge Config token for sub-5ms tenant lookup at the edge.
EDGE_CONFIG=

# Optional: Upstash Redis.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Server-only revalidate webhook secret.
STOREFRONT_REVALIDATE_SECRET=changeme-rotate-before-prod

# Comma-separated tenant storefront hosts that should be pinged to Google/Bing
# whenever their content tag is revalidated. Example:
#   STOREFRONT_PING_SITEMAP_HOSTS=https://nozeperfume.com,https://thebrownbutter.com
# Leave empty in dev.
STOREFRONT_PING_SITEMAP_HOSTS=
