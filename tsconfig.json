{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "es6"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"],
      "@profixer/types": ["../packages/types/src"],
      "@profixer/types/*": ["../packages/types/src/*"],
      "@profixer/rbac": ["../packages/rbac/src"],
      "@profixer/constants": ["../packages/constants/src"],
      "@profixer/utils": ["../packages/utils/src"],
      "@profixer/api-client": ["../packages/api-client/src"]
    }
  },
  "include": [
    "src",
    "packages/types/src",
    "packages/rbac/src",
    "packages/constants/src",
    "packages/utils/src"
  ]
}