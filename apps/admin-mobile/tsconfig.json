{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@profixer/api-client": ["../../packages/api-client/src"],
      "@profixer/constants": ["../../packages/constants/src"],
      "@profixer/rbac": ["../../packages/rbac/src"],
      "@profixer/types": ["../../packages/types/src"],
      "@profixer/utils": ["../../packages/utils/src"]
    }
  },
  "include": ["src", "index.js"]
}
