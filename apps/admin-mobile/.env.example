# react-native-config — baked into the native app at build time.
# After editing, rebuild: npm run android  (or npm run ios)
#
# Health check: http://localhost:8005/health
# API base (must include /api): http://localhost:8005/api

# Android emulator → host machine (NOT localhost):
API_URL=http://10.0.2.2:8005/api

# iOS simulator → host machine:
# API_URL=http://localhost:8005/api

# Physical device → your Mac's LAN IP:
# API_URL=http://192.168.1.100:8005/api

# Match web admin when using multi-tenant API (see root .env REACT_APP_SAAS_MODE)
# SAAS_MODE=true
# TENANT_HEADER=X-Tenant-Id
# DEFAULT_TENANT_ID=

# ONESIGNAL_APP_ID=
# GOOGLE_MAPS_API_KEY=
