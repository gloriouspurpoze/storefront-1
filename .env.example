# =============================================================================
# Profixer Storefront — environment template
#
# For local dev: copy to `.env.local` and use localhost values.
# For prod: set the same keys in Vercel → Project → Settings → Env Variables
#           (Production + Preview). Do NOT commit real secrets here.
# =============================================================================

# ---------- REQUIRED ----------

# Backend API base URL, no trailing slash.
#   Local : http://localhost:8005/api
#   Prod  : https://api.<your-domain>/api
NEXT_PUBLIC_API_BASE_URL=http://localhost:8005/api

# Comma-separated host suffixes the storefront treats as platform subdomains.
# The middleware strips these to extract the tenant slug.
#   Local : profixer.localhost,localhost
#   Prod  : shop.<your-domain>          (e.g. shop.profixer.in)
# Multiple suffixes are allowed; the first match wins.
NEXT_PUBLIC_STOREFRONT_HOST_SUFFIXES=profixer.app,profixer.localhost,localhost

# Server-only secret the backend uses when calling /api/revalidate on the
# storefront. MUST match STOREFRONT_REVALIDATE_SECRET on the API server.
# Generate with: openssl rand -hex 32
STOREFRONT_REVALIDATE_SECRET=changeme-rotate-before-prod

# ---------- OPTIONAL (production niceties) ----------

# Vercel Edge Config token. Enables sub-5 ms host → tenant lookup at the edge
# instead of hitting the API. Only set this once you have it provisioned.
EDGE_CONFIG=

# Upstash Redis for multi-region storefront cache (optional).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Comma-separated fully-qualified tenant URLs to ping Google/Bing whenever
# their content tag revalidates. Leave empty in dev.
#   Example: https://nozeperfume.com,https://thebrownbutter.com
STOREFRONT_PING_SITEMAP_HOSTS=
