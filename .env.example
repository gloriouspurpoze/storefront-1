# Fixer Admin – environment variables
# Copy this file to .env and fill in values. Do not commit .env.

# ─── SaaS / multi-tenant (optional) ─────────────────────────────────────────
# When your API scopes data by organization, return tenant/organization id on login
# or profile and/or accept the header below on every request (backend must enforce).
# REACT_APP_SAAS_MODE=true
# REACT_APP_TENANT_HEADER=X-Tenant-Id
# REACT_APP_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000000

# API base URL (no trailing slash). Used by api base, apiClient, CMS, uploads, etc.
# Production: https://api.profixer.in/api (Socket.IO strips /api and uses https://api.profixer.in/chat)
# API must allow CORS from https://admin.profixer.in — see docs/CORS_PROXY_FIX.md
REACT_APP_API_URL=http://localhost:5000/api

# ─── CRM (fixer-backend /api/crm) ─────────────────────────────────────────────
# Enable live CRM: MongoDB + RBAC permissions view_crm / manage_crm.
# Backend seed: cd fixer-backend && npm run seed:crm-permissions
# REACT_APP_CRM_USE_API=true
#
# Production launch (admin + backend — verify before go-live):
# - Secrets: JWT_SECRET / CRM_GOOGLE_* only in host env or secrets manager; never commit .env
# - HTTPS: admin and API both HTTPS; OAuth redirect URIs use production URLs only
# - MongoDB: backups + restore tested; connection string not in client bundles
# - RBAC: view_crm / manage_crm assigned to correct roles; test staff vs manager field rules
# - CORS: REACT_APP_API_URL origin allowed for your admin domain (see backend CORS config)
# - Google Cloud: OAuth consent published; redirect = backend CRM_GOOGLE_REDIRECT_URI exactly
# - Sync: rate-limit / monitor POST /api/crm/sync/* ; plan token encryption at rest if required
# - Legal: privacy notice for Gmail/calendar read sync; data retention for CRM collections
# - Smoke test: contacts CRUD, export CSV, field mask for non-admin, OAuth reconnect flow

# Optional: public marketing site origin (no trailing slash) — used for blog SERP preview in the editor
# REACT_APP_PUBLIC_SITE_ORIGIN=https://www.profixer.in

# Optional: WebSocket server (if different from API host)
# REACT_APP_WS_URL=ws://localhost:5000
