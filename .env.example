# Fixer Admin – environment variables
# Copy this file to .env and fill in values. Do not commit .env.

# API base URL (no trailing slash). Used by api base, apiClient, CMS, uploads, etc.
# Production: https://api.profixer.in/api (API must allow CORS from https://admin.profixer.in — see docs/CORS_FOR_ADMIN.md)
REACT_APP_API_URL=http://localhost:5000/api

# Optional: public marketing site origin (no trailing slash) — used for blog SERP preview in the editor
# REACT_APP_PUBLIC_SITE_ORIGIN=https://www.profixer.in

# Optional: WebSocket server (if different from API host)
# REACT_APP_WS_URL=ws://localhost:5000
