# Local dev — API on same port as fixer-backend (`PORT` in fixer-backend/.env)
REACT_APP_API_URL=http://localhost:8005/api

# OneSignal Web — must match fixer-client `NEXT_PUBLIC_ONESIGNAL_APP_ID` and fixer-backend `ONESIGNAL_APP_ID`
# In OneSignal Dashboard → your Web app → allow every origin you use, e.g. http://localhost:3000 and
# http://localhost:3001 (CRA may use 3001 if 3000 is taken), plus https://admin.profixer.in in prod.
REACT_APP_ONESIGNAL_APP_ID=93bf2a95-c16f-4973-b0ba-0489fa5f0a63
REACT_APP_ONESIGNAL_SAFARI_WEB_ID=web.onesignal.auto.0f4ef0fc-d020-4184-9066-253532c318fc

REACT_APP_CRM_USE_API=true
REACT_APP_API_URL=http://localhost:8005/api